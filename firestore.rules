rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Root user profile document
    match /users/{userId} {
      allow read, create, update: if isSelf(userId);
      allow delete: if false;

      // App-level preferences used by sidebar/session state
      match /preferences/{docId} {
        allow read, write: if isSelf(userId) && docId == 'app';
      }

      // Per-course progress bucket
      match /events/{eventId} {
        allow read, write: if isSelf(userId)
          && (!request.resource.data.keys().hasAll(['eventId'])
              || request.resource.data.eventId == eventId);

        match /sessions/{sessionId} {
          allow read, delete: if isSelf(userId);

          allow create, update: if isSelf(userId)
            && request.resource.data.keys().hasAll([
              'sessionId',
              'sessionType',
              'event',
              'startTimestamp',
              'totalQuestions',
              'correctCount',
              'accuracy',
              'attempts'
            ])
            && request.resource.data.sessionId is string
            && request.resource.data.sessionType is string
            && request.resource.data.event is string
            && request.resource.data.startTimestamp is string
            && request.resource.data.totalQuestions is int
            && request.resource.data.correctCount is int
            && request.resource.data.accuracy is number
            && request.resource.data.attempts is string
            && request.resource.data.correctCount >= 0
            && request.resource.data.totalQuestions >= 0
            && request.resource.data.accuracy >= 0
            && request.resource.data.accuracy <= 100;
        }
      }
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
