rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOrgMember(orgId) {
      return isSignedIn() && exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid));
    }

    function isOrgOwner(orgId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role == 'owner';
    }

    // Legacy path retained only for profile reads/writes during migration.
    match /users/{userId} {
      allow read, create, update: if isSignedIn() && request.auth.uid == userId;
    }

    match /organizations/{orgId} {
      allow read: if isOrgMember(orgId);
      allow create: if isSignedIn() && request.auth.uid == orgId
        && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isOrgOwner(orgId);
      allow delete: if false;

      // Org membership records
      match /members/{memberId} {
        allow read: if isOrgMember(orgId);
        allow create: if isSignedIn() && request.auth.uid == orgId && memberId == request.auth.uid
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.role == 'owner';
        allow update: if isOrgOwner(orgId) || (isSignedIn() && request.auth.uid == memberId);
        allow delete: if false;
      }

      // App-level preferences (courses, current session)
      match /preferences/{docId} {
        allow read, write: if isOrgMember(orgId)
          && docId == 'app';
      }

      // Event progress buckets per course
      match /events/{eventId} {
        allow read, write: if isOrgMember(orgId)
          && (!request.resource.data.keys().hasAll(['eventId']) || request.resource.data.eventId == eventId);

        match /sessions/{sessionId} {
          allow read, delete: if isOrgMember(orgId);

          allow create, update: if isOrgMember(orgId)
            && request.resource.data.keys().hasAll([
              'sessionId',
              'sessionType',
              'event',
              'startTimestamp',
              'totalQuestions',
              'correctCount',
              'accuracy',
              'attempts'
            ])
            && request.resource.data.sessionId is string
            && request.resource.data.sessionType is string
            && request.resource.data.event is string
            && request.resource.data.startTimestamp is string
            && request.resource.data.totalQuestions is int
            && request.resource.data.correctCount is int
            && request.resource.data.accuracy is number
            && request.resource.data.attempts is string
            && request.resource.data.correctCount >= 0
            && request.resource.data.totalQuestions >= 0
            && request.resource.data.accuracy >= 0
            && request.resource.data.accuracy <= 100;
        }
      }
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
