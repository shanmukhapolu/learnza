rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Deny everything by default
    match /{document=**} {
      allow read, write: if false;
    }

    // -----------------------------------------------------------------------
    // /users/{userId}
    //   Fields on this document:
    //     - firstName, lastName, name   (set by saveUserProfile)
    //     - addedCourses                (array of course IDs, e.g. ["ap-bio"])
    //     - currentSession              (JSON string of in-progress session)
    // -----------------------------------------------------------------------
    match /users/{userId} {
      allow read, update: if request.auth != null && request.auth.uid == userId;
      // Allow create so signup can write the profile document
      allow create: if request.auth != null && request.auth.uid == userId;

      // -----------------------------------------------------------------------
      // /users/{userId}/events/{eventId}
      //   Fields on this document:
      //     - eventId           (string, e.g. "ap-bio")
      //     - wrongQuestions    (array of int question IDs)
      //     - completedQuestions (array of int question IDs)
      //
      //   This document is created/upserted before any session is saved so
      //   it always exists as a parent for the sessions subcollection.
      // -----------------------------------------------------------------------
      match /events/{eventId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;

        // Validate writes: eventId must match the document ID
        allow create, update: if request.auth != null
          && request.auth.uid == userId
          && (!request.resource.data.keys().hasAll(['eventId'])
              || request.resource.data.eventId == eventId);

        // -----------------------------------------------------------------------
        // /users/{userId}/events/{eventId}/sessions/{sessionId}
        //   Fields on this document:
        //     - sessionId         (string)
        //     - sessionType       ("practice" | "timed")
        //     - event             (string, matches eventId)
        //     - startTimestamp    (ISO string)
        //     - endTimestamp      (ISO string)
        //     - totalThinkTime    (number)
        //     - totalExplanationTime (number)
        //     - totalQuestions    (number)
        //     - correctCount      (number)
        //     - accuracy          (number 0-100)
        //     - attempts          (JSON string — serialised array)
        // -----------------------------------------------------------------------
        match /sessions/{sessionId} {
          allow read, delete: if request.auth != null && request.auth.uid == userId;

          allow create, update: if request.auth != null
            && request.auth.uid == userId
            // Required fields
            && request.resource.data.keys().hasAll(['sessionId', 'sessionType', 'event',
                'startTimestamp', 'totalQuestions', 'correctCount', 'accuracy', 'attempts'])
            // Type checks
            && request.resource.data.sessionId is string
            && request.resource.data.event is string
            && request.resource.data.startTimestamp is string
            && request.resource.data.totalQuestions is int
            && request.resource.data.correctCount is int
            && request.resource.data.accuracy is number
            && request.resource.data.attempts is string
            // Sanity bounds
            && request.resource.data.correctCount >= 0
            && request.resource.data.totalQuestions >= 0
            && request.resource.data.accuracy >= 0
            && request.resource.data.accuracy <= 100;
        }
      }
    }
  }
}
